        <mxCell id="n_01" value="1 前準備&#xa;やること: 認証突破してログイン&#xa;開始: https://development.pocket-heroes.net/home" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="80" y="140" width="1000" height="90" as="geometry"/></mxCell>
